# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env.local contains local-only secrets — never commit
.env.local
# .env.*.local are per-developer local overrides — never commit
.env.*.local
# .env.production IS committed so Vercel reads NEXT_PUBLIC_* at build time
# (NEXT_PUBLIC_API_URL is a public URL, not a secret)
# !.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
